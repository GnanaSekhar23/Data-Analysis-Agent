# Database — GCP Cloud SQL
DB_HOST=your-cloud-sql-public-ip
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=olist_db
DATABASE_URL=mysql+pymysql://your_db_user:your_db_password@your-cloud-sql-public-ip/olist_db

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# LLM — choose one:
# Option 1: Direct Grok API (console.x.ai)
XAI_API_KEY=xai-your-key-here

# Option 2: Google AI Studio (aistudio.google.com)
# GOOGLE_API_KEY=your-google-api-key

# Option 3: Anthropic (console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
